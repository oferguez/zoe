# Frontend-only prototype settings.
# Do not put secret API keys in NEXT_PUBLIC_* variables.
NEXT_PUBLIC_ANALYSIS_SERVICE_MODE=mock
NEXT_PUBLIC_EXTERNAL_TARGETS=large-llm,public-forum

# Private chat agent gateway (see Doc/FRONTEND_INTEGRATION.md).
# Server-side only - read by src/app/api/chat/route.ts, never sent to the browser.
# Ask the project owner for the token, or find it in infra/terraform.tfvars.
GATEWAY_URL=https://dt2lozk8ne2zy.cloudfront.net
GATEWAY_TOKEN=

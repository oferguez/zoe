APP_NAME=Zoe Assist
APP_SECRET=replace-with-a-long-random-secret

# Preferred: 32 random bytes, base64 encoded.
# Example: openssl rand -base64 32
DOCUMENT_ENCRYPTION_KEY=Q6/WKRaugSqCTAEKjea+o1hwWiJHakYLPhEYLDyfPsQ=

# Routing and local-answer policy
DECISION_PROVIDER=heuristic
LOCAL_ANSWER_MAX_CHARS=420
REQUIRE_EXTERNAL_APPROVAL=true
CASE_TTL_MINUTES=30

# Upload limits
MAX_DOCUMENTS=5
MAX_DOCUMENT_BYTES=1048576

# Optional small, fast LLM for routing/local answers.
# The URL shape is OpenAI-compatible chat completions.
SMALL_LLM_PROVIDER=heuristic
SMALL_LLM_API_URL=https://api.openai.com/v1/chat/completions
SMALL_LLM_API_KEY=
SMALL_LLM_MODEL=gpt-4o-mini

# Optional larger LLM for approved escalations.
LARGE_LLM_PROVIDER=mock
LARGE_LLM_API_URL=https://api.openai.com/v1/chat/completions
LARGE_LLM_API_KEY=
LARGE_LLM_MODEL=gpt-4.1

# Comma-separated policy knobs.
HIGH_RISK_KEYWORDS=diagnosis,prescription,dosage,symptoms,chest pain,pregnant,suicidal,emergency,medication,lab results,blood test,mri,scan,pathology
DOCUMENT_REQUEST_KEYWORDS=lab,result,report,scan,mri,ct,xray,blood,test,history,medication,prescription,discharge
